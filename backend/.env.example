PORT=3000
HOST=0.0.0.0
DB_PATH=./central.db

# External MQTT broker (public HiveMQ by default). For a private broker set the
# tcp://host:port URL plus MQTT_USERNAME / MQTT_PASSWORD as needed.
MQTT_BROKER=tcp://broker.hivemq.com:1883
MQTT_TOPIC_PREFIX=XSSF2026MMAA

# Client ID must be unique on the broker. Leave blank to auto-generate
# "central-backend-<8hex>" on each start.
MQTT_CLIENT_ID=
MQTT_USERNAME=
MQTT_PASSWORD=
